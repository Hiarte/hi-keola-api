# Copier ce fichier vers .env et remplir les valeurs.

TWITCH_CHANNEL=ton_channel
TWITCH_TARGET_USERNAME=pseudo_a_traiter

# API Fastify (optionnel — défaut : 3000 si non défini)
# PORT=55550
# HOST=0.0.0.0
#
# URL publique de l’API (HTTPS derrière reverse proxy) — pour les liens MP3 dans /tts/.../playback
# PUBLIC_BASE_URL=https://ton-domaine.tld
# Ex. Render : PUBLIC_BASE_URL=https://hi-keola-api.onrender.com
#
# Fenêtre « live » TTS (ms, défaut : 10000) : même valeur pour (1) GET /tts/:streamId/playback — segments ready trop vieux ignorés,
# (2) worker — pas de synthèse ElevenLabs ni mise en ready depuis le cache si l’item dépasse ce délai depuis l’enqueue (`createdAt`).
# TTS_PLAYBACK_MAX_AGE_MS=10000

# CORS (POC extension dans le navigateur)
# - En local, sans NODE_ENV=production : CORS déjà ouvert par défaut (rien à mettre).
# - En prod (Render, etc.) : définis une origine ou tout autoriser :
# CORS_ORIGIN=*
# ou CORS_ORIGIN=https://extension-host.twitch.tv,http://127.0.0.1:5500
# Pour désactiver explicitement : CORS_ORIGIN=false

# Fichier JSON des stats messages (optionnel — défaut : ./data/normalized-messages.json)
# STATS_PERSIST_PATH=./data/normalized-messages.json
#
# Mots → traduction TTS (défaut : ./tts-word-map.json à la racine) — ex. { "XD": "[laughs]." } ; correspondance mot entier, casse ignorée.

# Pipeline TTS (cache JSON + file + worker ElevenLabs)
#
# STREAM_ID — identifiant logique du « flux » pour numéroter les messages (séquence TTS).
#   Souvent = nom du channel ou un ID stable (ex. login Twitch). Si absent : même valeur que TWITCH_CHANNEL.
# STREAM_ID=mon-stream
#
# TTS_PROVIDER=elevenlabs
# Clé API (https://elevenlabs.io → Profil / API Key)
# TTS_API_KEY=
# ELEVENLABS_API_KEY=
#
# Voice ID ElevenLabs (chaîne type JBFqnCBsd6RMkjVDRZzb — pas le nom affiché du voice)
# TTS_VOICE=
#
# Modèle TTS (UI « Eleven v3 » → souvent eleven_v3 ; sinon voir GET https://api.elevenlabs.io/v1/models)
# ELEVENLABS_MODEL_ID=eleven_v3
#
# Stabilité (API 0–1 : créatif → robuste). Valeur > 1 = interprétée comme pourcentage (ex. 55 → 0,55)
# ELEVENLABS_STABILITY=0.55
#
# Optionnel : similarité / vitesse de voix (API voice_settings)
# ELEVENLABS_SIMILARITY_BOOST=0.75
# ELEVENLABS_VOICE_SPEED=1
#
# Sortie audio (query output_format, ex. mp3_44100_128 — doc Text to Speech)
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_API_BASE=https://api.elevenlabs.io
#
# TTS_FORMAT=mp3
# TTS_SPEED=1
# TTS_PITCH=0
# TTS_QUEUE_PATH=./data/tts-queue.json
# TTS_AUDIO_CACHE_PATH=./data/audio-cache.json
#
# TTS_WORKER_ENABLED — true = boucle qui prend les jobs "pending" (sinon rien ne sort de la file sans worker externe)
# TTS_WORKER_ENABLED=false
#
# TTS_WORKER_POLL_MS — délai en ms entre deux tentatives de récupération d’un job pending
# TTS_WORKER_POLL_MS=3000
#
# TTS_WORKER_ID — libellé pour savoir quel processus a verrouillé l’item (logs / debug multi-instances)
# TTS_WORKER_ID=worker-1
